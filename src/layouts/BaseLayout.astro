---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Espanol',
  zh: '中文',
  ru: 'Русский',
  pt: 'Portugues',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #f5e6c8;
        background: #0a0c12;
      }
      a {
        color: #d4a853;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        color: #e6c078;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }
      header {
        background: rgba(10, 12, 18, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(212, 168, 83, 0.3);
        color: white;
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.4rem;
        font-weight: 700;
        color: #d4a853;
        letter-spacing: -0.01em;
      }
      .logo:hover {
        text-decoration: none;
        color: #e6c078;
      }
      nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      nav a {
        color: rgba(245, 230, 200, 0.6);
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        transition: all 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #d4a853;
        background: rgba(212, 168, 83, 0.1);
        text-decoration: none;
      }
      main {
        min-height: 70vh;
        padding: 40px 0;
      }
      footer {
        background: rgba(10, 12, 18, 0.95);
        border-top: 1px solid rgba(212, 168, 83, 0.15);
        color: rgba(245, 230, 200, 0.4);
        padding: 24px 0;
        text-align: center;
        font-size: 0.85rem;
      }
      .ad-slot {
        background: rgba(212, 168, 83, 0.04);
        border: 1px dashed rgba(212, 168, 83, 0.15);
        padding: 20px;
        text-align: center;
        margin: 24px 0;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(245, 230, 200, 0.25);
        font-size: 0.8rem;
        border-radius: 8px;
      }
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        margin: 32px 0;
      }
      .card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(212, 168, 83, 0.1);
        border-radius: 12px;
        padding: 28px;
        transition: all 0.3s ease;
      }
      .card:hover {
        background: rgba(212, 168, 83, 0.06);
        border-color: rgba(212, 168, 83, 0.35);
        transform: translateY(-3px);
        box-shadow: 0 8px 32px rgba(212, 168, 83, 0.08);
      }
      .card h2 {
        font-size: 1.3rem;
        margin-bottom: 10px;
        color: #d4a853;
        font-weight: 600;
      }
      .card p {
        color: rgba(245, 230, 200, 0.6);
        font-size: 0.95rem;
        line-height: 1.7;
      }
      @media (max-width: 640px) {
        .card-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">Site</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">Site</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

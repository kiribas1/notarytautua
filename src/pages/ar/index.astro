---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotaryQuiz from '../../components/NotaryQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="كاتب عدل كيريباتي - السيدة تيكاريي تاوتوا | خدمات توثيق معتمدة"
  description="السيدة تيكاريي تاوتوا، كاتب عدل معين رسمياً في جمهورية كيريباتي. توثيق ومصادقة احترافية للوثائق القانونية للاستخدام المحلي والدولي."
  lang="ar"
>
  <Fragment slot="logo">Notary Tautua</Fragment>
  <Fragment slot="footer-name">تيكاريي تاوتوا – كاتب عدل، جمهورية كيريباتي</Fragment>

  <section class="nt-hero">
    <div class="nt-hero-bg"></div>
    <div class="nt-hero-overlay"></div>
    <div class="nt-hero-content">
      <h1 class="nt-title">كاتب عدل</h1>
      <p class="nt-name">السيدة تيكاريي تاوتوا</p>
      <p class="nt-lead">تقديم خدمات توثيقية احترافية بنزاهة ودقة واحترام كامل للمعايير القانونية.</p>
    </div>
  </section>

  <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

  <div class="card-grid">
    <article class="card">
      <h2>توثيق المستندات</h2>
      <p>التوثيق الرسمي للمستندات القانونية بما في ذلك الإفادات المشفوعة بيمين والإعلانات القانونية والتوكيلات والبيانات المحلفة للاستخدام في كيريباتي والخارج.</p>
    </article>
    <article class="card">
      <h2>المصادقة الدولية</h2>
      <p>مصادقة وتصديق المستندات للاستخدام الدولي. دعم الأفراد والشركات والجهات الحكومية في احتياجات التوثيق العابرة للحدود.</p>
    </article>
    <article class="card">
      <h2>الشهادة والتصديق</h2>
      <p>شهادة احترافية على التوقيعات والقسم والتأكيدات. كل تصديق يتم بالتزام صارم بالمتطلبات القانونية المعمول بها.</p>
    </article>
    <article class="card">
      <h2>النسخ المصدقة</h2>
      <p>إعداد وتصديق نسخ طبق الأصل من المستندات الأصلية للأغراض القانونية والهجرة والإدارية.</p>
    </article>
    <article class="card">
      <h2>الخدمات التجارية</h2>
      <p>خدمات توثيقية للمستندات المؤسسية والعقود واتفاقيات الشراكة والمعاملات التجارية التي تتطلب مصادقة رسمية.</p>
    </article>
    <article class="card">
      <h2>السرية والنزاهة</h2>
      <p>يتم تقديم كل خدمة بسرية تامة ودقة والتزام بالمتطلبات القانونية المعمول بها في جمهورية كيريباتي.</p>
    </article>
  </div>

  <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

  <NotaryQuiz lang="ar" />

  <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

  <WeeklyNews lang="ar" />

  <section class="contact-info">
    <h2>اتصل بنا</h2>
    <p><strong>تيكاريي تاوتوا</strong> – كاتب عدل</p>
    <p>بيتيو، جنوب تاراوا</p>
    <p>صندوق بريد 118</p>
    <p>جمهورية كيريباتي</p>
  </section>

  <div class="ad-slot">مساحة إعلانية - Google AdSense</div>
</BaseLayout>

<style>
  .nt-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: -40px -20px 0;
    padding: 0;
  }
  .nt-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/notary.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .nt-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10,12,18,.55) 0%,
      rgba(10,12,18,.7) 50%,
      rgba(10,12,18,.85) 100%
    );
  }
  .nt-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    padding: 40px 24px;
  }
  .nt-title {
    font-size: 4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
    text-shadow: 0 4px 20px rgba(0,0,0,.5);
    letter-spacing: -.02em;
    line-height: 1.1;
  }
  .nt-name {
    font-size: 2rem;
    font-weight: 700;
    color: #d4a853;
    margin-bottom: 20px;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
  }
  .nt-lead {
    font-size: 1.15rem;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
    text-shadow: 0 1px 6px rgba(0,0,0,.3);
  }
  @media (max-width: 640px) {
    .nt-title { font-size: 2.4rem; }
    .nt-name { font-size: 1.4rem; }
    .nt-lead { font-size: 1rem; }
  }
  .contact-info {
    background: rgba(212,168,83,.04);
    border: 1px solid rgba(212,168,83,.12);
    border-radius: 12px;
    padding: 32px;
    margin-top: 32px;
    text-align: center;
  }
  .contact-info h2 {
    margin-bottom: 16px;
    color: #d4a853;
    font-size: 1.4rem;
  }
  .contact-info p {
    margin: 6px 0;
    color: rgba(245,230,200,.55);
  }
</style>

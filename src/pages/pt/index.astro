---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotaryQuiz from '../../components/NotaryQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Notario Publico Kiribati - Sra. Tekarei Tautua | Servicos Notariais Certificados"
  description="Sra. Tekarei Tautua, Notario Publico da Republica de Kiribati. Certificacao e autenticacao profissional de documentos legais para uso nacional e internacional."
  lang="pt"
>
  <Fragment slot="logo">Notary Tautua</Fragment>
  <Fragment slot="footer-name">Tekarei Tautua – Notario Publico, Republica de Kiribati</Fragment>

  <section class="nt-hero">
    <div class="nt-hero-bg"></div>
    <div class="nt-hero-overlay"></div>
    <div class="nt-hero-content">
      <h1 class="nt-title">Notario Publico</h1>
      <p class="nt-name">Sra. Tekarei Tautua</p>
      <p class="nt-lead">Servicos notariais profissionais com integridade, precisao e pleno respeito aos padroes legais.</p>
    </div>
  </section>

  <div class="ad-slot">Espaco Publicitario - Google AdSense</div>

  <div class="card-grid">
    <article class="card">
      <h2>Certificacao de Documentos</h2>
      <p>Certificacao oficial de documentos legais incluindo declaracoes juramentadas, procuracoes e declaracoes sob juramento para uso em Kiribati e no exterior.</p>
    </article>
    <article class="card">
      <h2>Autenticacao Internacional</h2>
      <p>Autenticacao e legalizacao de documentos para uso internacional. Apoio a individuos, empresas e agencias governamentais com necessidades de documentacao transfronteirica.</p>
    </article>
    <article class="card">
      <h2>Testemunho e Atestacao</h2>
      <p>Testemunho profissional de assinaturas, juramentos e afirmacoes. Cada atestacao realizada com estrito cumprimento dos requisitos legais aplicaveis.</p>
    </article>
    <article class="card">
      <h2>Copias Certificadas</h2>
      <p>Preparacao e certificacao de copias fieis de documentos originais para fins legais, imigratorios e administrativos.</p>
    </article>
    <article class="card">
      <h2>Servicos Comerciais</h2>
      <p>Servicos notariais para documentos corporativos, contratos, acordos de parceria e transacoes comerciais que exigem autenticacao oficial.</p>
    </article>
    <article class="card">
      <h2>Confidencialidade e Integridade</h2>
      <p>Cada servico e prestado com estrita confidencialidade, precisao e cumprimento dos requisitos legais aplicaveis da Republica de Kiribati.</p>
    </article>
  </div>

  <div class="ad-slot">Espaco Publicitario - Google AdSense</div>

  <NotaryQuiz lang="pt" />

  <div class="ad-slot">Espaco Publicitario - Google AdSense</div>

  <WeeklyNews lang="pt" />

  <section class="contact-info">
    <h2>Contato</h2>
    <p><strong>Tekarei Tautua</strong> – Notario Publico</p>
    <p>Betio, South Tarawa</p>
    <p>P.O. Box 118</p>
    <p>Republica de Kiribati</p>
  </section>

  <div class="ad-slot">Espaco Publicitario - Google AdSense</div>
</BaseLayout>

<style>
  .nt-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: -40px -20px 0;
    padding: 0;
  }
  .nt-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/notary.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .nt-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10,12,18,.55) 0%,
      rgba(10,12,18,.7) 50%,
      rgba(10,12,18,.85) 100%
    );
  }
  .nt-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    padding: 40px 24px;
  }
  .nt-title {
    font-size: 4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
    text-shadow: 0 4px 20px rgba(0,0,0,.5);
    letter-spacing: -.02em;
    line-height: 1.1;
  }
  .nt-name {
    font-size: 2rem;
    font-weight: 700;
    color: #d4a853;
    margin-bottom: 20px;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
  }
  .nt-lead {
    font-size: 1.15rem;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
    text-shadow: 0 1px 6px rgba(0,0,0,.3);
  }
  @media (max-width: 640px) {
    .nt-title { font-size: 2.4rem; }
    .nt-name { font-size: 1.4rem; }
    .nt-lead { font-size: 1rem; }
  }
  .contact-info {
    background: rgba(212,168,83,.04);
    border: 1px solid rgba(212,168,83,.12);
    border-radius: 12px;
    padding: 32px;
    margin-top: 32px;
    text-align: center;
  }
  .contact-info h2 {
    margin-bottom: 16px;
    color: #d4a853;
    font-size: 1.4rem;
  }
  .contact-info p {
    margin: 6px 0;
    color: rgba(245,230,200,.55);
  }
</style>

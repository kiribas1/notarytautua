---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotaryQuiz from '../../components/NotaryQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Notary Public Kiribati - Ms. Tekarei Tautua | Certified Notarial Services"
  description="Ms. Tekarei Tautua, duly appointed Notary Public of the Republic of Kiribati. Professional certification and authentication of legal documents for domestic and international use."
  lang="en"
>
  <Fragment slot="logo">Notary Tautua</Fragment>
  <Fragment slot="footer-name">Tekarei Tautua – Notary Public, Republic of Kiribati</Fragment>

  <section class="nt-hero">
    <div class="nt-hero-bg"></div>
    <div class="nt-hero-overlay"></div>
    <div class="nt-hero-content">
      <h1 class="nt-title">Notary Public</h1>
      <p class="nt-name">Ms. Tekarei Tautua</p>
      <p class="nt-lead">Providing professional notarial services with integrity, precision, and full respect for legal standards.</p>
    </div>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <div class="card-grid">
    <article class="card">
      <h2>Document Certification</h2>
      <p>Official certification of legal documents including affidavits, statutory declarations, powers of attorney, and sworn statements for use in Kiribati and abroad.</p>
    </article>
    <article class="card">
      <h2>International Authentication</h2>
      <p>Authentication and legalization of documents for international use. Supporting individuals, businesses, and government agencies with cross-border documentation needs.</p>
    </article>
    <article class="card">
      <h2>Witnessing & Attestation</h2>
      <p>Professional witnessing of signatures, oaths, and affirmations. Each attestation performed with strict adherence to applicable legal requirements.</p>
    </article>
    <article class="card">
      <h2>Certified Copies</h2>
      <p>Preparation and certification of true copies of original documents for legal, immigration, and administrative purposes.</p>
    </article>
    <article class="card">
      <h2>Business & Commercial Services</h2>
      <p>Notarial services for corporate documents, contracts, partnership agreements, and commercial transactions requiring official authentication.</p>
    </article>
    <article class="card">
      <h2>Confidentiality & Integrity</h2>
      <p>Each service is delivered with strict confidentiality, accuracy, and adherence to applicable legal requirements of the Republic of Kiribati.</p>
    </article>
  </div>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <NotaryQuiz lang="en" />

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <WeeklyNews lang="en" />

  <section class="contact-info">
    <h2>Contact</h2>
    <p><strong>Tekarei Tautua</strong> – Notary Public</p>
    <p>Betio, South Tarawa</p>
    <p>P.O. Box 118</p>
    <p>Republic of Kiribati</p>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>
</BaseLayout>

<style>
  .nt-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin: -40px -20px 0;
    padding: 0;
  }
  .nt-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/notary.webp');
    background-size: contain;
    background-position: center center;
    background-color: #0a0c12;
    background-repeat: no-repeat;
  }
  .nt-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10,12,18,.55) 0%,
      rgba(10,12,18,.7) 50%,
      rgba(10,12,18,.85) 100%
    );
  }
  .nt-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    padding: 40px 24px;
  }
  .nt-title {
    font-size: 4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
    text-shadow: 0 4px 20px rgba(0,0,0,.5);
    letter-spacing: -.02em;
    line-height: 1.1;
  }
  .nt-name {
    font-size: 2rem;
    font-weight: 700;
    color: #d4a853;
    margin-bottom: 20px;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
  }
  .nt-lead {
    font-size: 1.15rem;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
    text-shadow: 0 1px 6px rgba(0,0,0,.3);
  }
  @media (max-width: 640px) {
    .nt-title { font-size: 2.4rem; }
    .nt-name { font-size: 1.4rem; }
    .nt-lead { font-size: 1rem; }
  }
  .contact-info {
    background: rgba(212,168,83,.04);
    border: 1px solid rgba(212,168,83,.12);
    border-radius: 12px;
    padding: 32px;
    margin-top: 32px;
    text-align: center;
  }
  .contact-info h2 {
    margin-bottom: 16px;
    color: #d4a853;
    font-size: 1.4rem;
  }
  .contact-info p {
    margin: 6px 0;
    color: rgba(245,230,200,.55);
  }
</style>
